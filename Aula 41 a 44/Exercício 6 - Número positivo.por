programa
{
    funcao inicio()
    {
        inteiro numero

        escreva ("Informe o número: ")
        leia(numero)

        se (numero > 0)
        {
            escreva("Numero positivo")
        }
    }
}

// erro de usabilidade: o algoritmo não pedia para informar o valor da variável
// o sinal estava incorreto, a condiçãp antes dizia que o número deveria ser menor que 0