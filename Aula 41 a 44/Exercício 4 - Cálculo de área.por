programa
{
    funcao inicio()
    {
        real largura, altura
        real area

        escreva ("Informe a largura: ")
        leia(largura)
        escreva ("Informe a altura: ")
        leia(altura)

        area = largura * altura

        escreva("Área: ", area)
    }
}

// erro de usabilidade, o algoritmo não pedia os valores das variáveis
// as variáveis de altura e largura foram declaradas de forma errada