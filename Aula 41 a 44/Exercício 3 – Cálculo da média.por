programa
{
    funcao inicio()
    {
        real n1, n2, media

        escreva ("Informe o valor da primeira nota: ")
        leia(n1)

        escreva ("Informe o valor da segunda nota: ")
        leia(n2)

        media = (n1 + n2) / 2

        escreva("Média: ", media)
    }
}

