programa {
  funcao inicio() {
    inteiro valor1, valor2

    escreva ("Informe o primeiro valor: ")
    leia(valor1)
    
    escreva ("Informe o segundo valor: ")
    leia(valor2)
    
    se (valor1 > valor2) {
      escreva ("o 1º valor é maior")}
    senao se (valor1 == valor2) {
      escreva ("os valores são iguais")}
      senao {escreva ("o 2º valor é maior")}

  
  }
}
