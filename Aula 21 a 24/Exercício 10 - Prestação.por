programa {
  funcao inicio() {
    real valorCompra, prestacao, valorMensal

    escreva ("Informe o valor da compra: R$")
    leia(valorCompra)

    escreva ("Informe a quantidade de prestações: ")
    leia (prestacao)

    valorMensal = valorCompra / prestacao 

    escreva ("O valor das prestações é: R$",valorMensal)


  }
}
