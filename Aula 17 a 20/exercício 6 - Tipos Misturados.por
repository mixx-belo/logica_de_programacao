programa {
  funcao inicio() {
    cadeia produto
    inteiro codigo
    real preco
    logico disponivel

    produto = "Detergente"
    codigo = 5306
    preco = 2.50
    disponivel = verdadeiro 

    escreva ("Nome do Produto: ", produto, "\n")
    escreva ("Código: ", codigo, "\n")
    escreva ("Preço: R$", preco, "\n")
    escreva ("Disponibilidade: ", disponivel )

  }
}
