programa {
  funcao inicio() {
    inteiro idade
    real altura
    logico alunoAtivo
    caracter sexo
    cadeia nomeCompleto

    idade = 22
    altura = 1.82
    alunoAtivo = verdadeiro
    sexo = 'M'
    nomeCompleto = "Michelder Belo Ferreira"

    escreva("Nome: ", nomeCompleto, "\n")
    escreva("Idade: ", idade, "\n")
    escreva("Altura: ", altura, "\n")
    escreva("Aluno ativo: ", alunoAtivo, "\n")
    escreva("Sexo: ", sexo)
  }
}
